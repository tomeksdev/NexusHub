{
  "annotations": { "list": [] },
  "description": "NexusHub — API, database, eBPF, and WireGuard at a glance. Import via Dashboards → New → Import, then pick the Prometheus datasource when prompted.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nexushub"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "current": {}
      },
      {
        "name": "interface",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(nexushub_wg_peers, interface)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "NexusHub — Overview",
  "uid": "nexushub-overview",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "API",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Build",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none"
      },
      "targets": [
        { "expr": "nexushub_build_info", "legendFormat": "{{version}} ({{commit}})", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Requests / s",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        { "expr": "sum(rate(nexushub_http_requests_total[5m]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "5xx error rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.02 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(rate(nexushub_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(nexushub_http_requests_total[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Auth 401s / s",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(rate(nexushub_http_requests_total{route=~\"/api/v1/auth/.*\",status=\"401\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "HTTP latency (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(nexushub_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(nexushub_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(nexushub_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Requests by route",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] } },
      "targets": [
        {
          "expr": "sum by (route) (rate(nexushub_http_requests_total[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "id": 101,
      "title": "Database",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "pgxpool connections",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] } },
      "targets": [
        { "expr": "nexushub_db_pool_acquired_conns", "legendFormat": "acquired", "refId": "A" },
        { "expr": "nexushub_db_pool_idle_conns",     "legendFormat": "idle",     "refId": "B" },
        { "expr": "nexushub_db_pool_total_conns",    "legendFormat": "total",    "refId": "C" },
        { "expr": "nexushub_db_pool_max_conns",      "legendFormat": "max",      "refId": "D" }
      ]
    },
    {
      "type": "gauge",
      "id": 8,
      "title": "Pool utilisation",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "red", "value": 0.95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "nexushub_db_pool_acquired_conns / clamp_min(nexushub_db_pool_max_conns, 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "id": 102,
      "title": "eBPF",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "BPF map entries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] } },
      "targets": [
        {
          "expr": "nexushub_ebpf_map_entries",
          "legendFormat": "{{map}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "BPF map utilisation",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] } },
      "targets": [
        {
          "expr": "nexushub_ebpf_map_entries / clamp_min(nexushub_ebpf_map_capacity, 1)",
          "legendFormat": "{{map}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "id": 103,
      "title": "WireGuard",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "id": 11,
      "title": "Peers per interface",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "nexushub_wg_peers{interface=~\"$interface\"}",
          "legendFormat": "{{interface}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 12,
      "title": "Throughput per peer (bytes/s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "rate(nexushub_wg_peer_receive_bytes_total{interface=~\"$interface\"}[5m])",
          "legendFormat": "rx {{interface}} {{public_key}}",
          "refId": "A"
        },
        {
          "expr": "rate(nexushub_wg_peer_transmit_bytes_total{interface=~\"$interface\"}[5m])",
          "legendFormat": "tx {{interface}} {{public_key}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "table",
      "id": 13,
      "title": "Peer handshake freshness",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 40 },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "seconds since last handshake" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 180 },
                    { "color": "red", "value": 600 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [
        {
          "expr": "time() - nexushub_wg_peer_last_handshake_seconds{interface=~\"$interface\"} and nexushub_wg_peer_last_handshake_seconds > 0",
          "legendFormat": "{{interface}} / {{public_key}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true } } }
      ]
    }
  ]
}
