# Go
backend/tmp/
cli/tmp/
cli/bin/
*.exe
*.test
*.out
vendor/

# Node
frontend/node_modules/
frontend/dist/
frontend/.vite/

# eBPF — bpf2go-generated files under ebpf/userspace/ are committed
# so downstream packages compile without clang. Stray .o files outside
# that directory (e.g. dev experiments) stay ignored.
ebpf/**/*.o
!ebpf/userspace/*.o

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Docker
docker/.env

# Coverage
coverage/
*.coverprofile
