# docker/.env — consumed by docker-compose.prod.yml.
# Copy to docker/.env and fill in the values. Never commit docker/.env.

# Image tag. "latest" tracks the most recent GHCR push; pin to a
# semver tag (e.g. v2.0.0) in production so upgrades are deliberate.
NEXUSHUB_TAG=latest

# Public hostname Caddy will request an ACME cert for. Must resolve
# to this host's IP before the stack starts; otherwise Let's Encrypt
# fails the HTTP-01 challenge.
NEXUSHUB_HOST=nexushub.example.com

# Postgres password. Use a long random string:
#   openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# Backend secrets. Same generation commands documented in
# deploy/systemd/env.example.
JWT_SECRET=CHANGE_ME
PEER_KEY_ENCRYPTION_KEY=CHANGE_ME

# Public WireGuard endpoint advertised in generated peer configs.
WG_ENDPOINT=vpn.example.com:51820

# Audit log retention window (days). 0 disables pruning.
AUDIT_RETENTION_DAYS=90
