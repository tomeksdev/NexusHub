# /etc/nexushub/env — consumed by the nexushub-api.service unit via
# EnvironmentFile=. Copy to /etc/nexushub/env, fill in the secrets,
# chmod 0600 (owner root, group nexushub readable), then
# `systemctl daemon-reload && systemctl restart nexushub-api`.

# --- Required --------------------------------------------------------------

DATABASE_URL=postgres://nexushub:CHANGE_ME@localhost:5432/nexushub?sslmode=require

# HS256 signing key for access tokens. 32+ random bytes.
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME

# AES-256-GCM master key encrypting wg_peers.private_key and
# users.totp_secret at rest. Exactly 32 bytes, base64-encoded.
#   openssl rand -base64 32
PEER_KEY_ENCRYPTION_KEY=CHANGE_ME

# --- Recommended -----------------------------------------------------------

# Public endpoint the generated peer configs advertise for reconnects.
# Without this the peer config renderer falls back to the interface
# endpoint column (which is often set at interface-create time).
WG_ENDPOINT=vpn.example.com:51820

# --- Defaults — override only if you know why -----------------------------

PORT=8080
GIN_MODE=release
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Audit retention. 0 disables pruning entirely; the loop exits at
# startup. 90 days is what most incident investigations need.
AUDIT_RETENTION_DAYS=90

# --- Optional: observability ----------------------------------------------

# OTLP/gRPC endpoint for traces. Leave empty to disable tracing;
# Init() installs a noop provider in that case.
# OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector.example.com:4317
# OTEL_EXPORTER_OTLP_INSECURE=false
# OTEL_SERVICE_NAME=nexushub
# OTEL_TRACES_SAMPLER_ARG=0.1
