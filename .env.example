# Database
DATABASE_URL=postgres://nexushub:nexushub@localhost:5432/nexushub?sslmode=disable

# Server
PORT=8080
GIN_MODE=release

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# 32-byte base64 key used to encrypt wg_peers.private_key at rest.
# Generate with: openssl rand -base64 32
PEER_KEY_ENCRYPTION_KEY=

# Initial seed admin (used by backend/cmd/seed)
NEXUSHUB_ADMIN_EMAIL=admin@example.com
NEXUSHUB_ADMIN_USERNAME=admin
NEXUSHUB_ADMIN_PASSWORD=change-me
NEXUSHUB_SEED_WG=0

# Email (SMTP default)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# WireGuard
WG_INTERFACE=wg0
WG_LISTEN_PORT=51820
WG_ENDPOINT=vpn.example.com
